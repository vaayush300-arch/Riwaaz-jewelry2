<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Riwaaz Jewelry – Tradition Meets Modernity</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--gold:#c9a84c;--gold-l:#e8c97a;--gold-d:#9a7530;--cream:#faf6f0;--deep:#1a0f0a;--text:#3a2a1e;--muted:#8a7060;--border:#e8ddd0;--white:#fff;--red:#c0392b;--green:#2d6a4f;--wa:#25d366}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden}

/* MARQUEE */
.mbar{background:var(--deep);color:var(--gold-l);padding:9px 0;overflow:hidden;white-space:nowrap;font-size:.76rem;letter-spacing:.04em}
.minner{display:inline-block;animation:tick 35s linear infinite}
.minner span{margin:0 2rem}.minner .sep{color:var(--gold)}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* HEADER */
header{background:var(--white);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:900;padding:0 1.25rem}
.hdr{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:62px}
.lname{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;color:var(--deep);letter-spacing:.04em;display:block}
.ltag{font-size:.6rem;color:var(--gold-d);letter-spacing:.18em;text-transform:uppercase;margin-top:1px;display:block}
.hcart{background:var(--deep);color:var(--gold-l);border:none;cursor:pointer;padding:.42rem 1rem;border-radius:30px;font-size:.78rem;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:.4rem;transition:background .2s}
.hcart:hover{background:var(--gold-d)}
.cbadge{background:var(--gold);color:var(--deep);border-radius:50%;width:18px;height:18px;font-size:.62rem;font-weight:700;display:flex;align-items:center;justify-content:center;min-width:18px}

/* HERO */
.hero{position:relative;overflow:hidden;height:min(90vh,660px)}
.hslide{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity 1.2s}
.hslide.on{opacity:1}
.hslide::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,15,10,.72) 0%,rgba(26,15,10,.3) 65%,transparent 100%)}
.hcnt{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;justify-content:center;padding:2rem 2rem 3rem;max-width:580px}
.heye{font-size:.68rem;color:var(--gold-l);letter-spacing:.22em;text-transform:uppercase;margin-bottom:.9rem;animation:fup .8s both}
.hh1{font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,6vw,3.8rem);font-weight:300;color:var(--white);line-height:1.15;margin-bottom:1.1rem;animation:fup .9s .1s both}
.hh1 em{font-style:italic;color:var(--gold-l)}
.hsub{font-size:.88rem;color:rgba(255,255,255,.76);margin-bottom:1.8rem;line-height:1.6;animation:fup .9s .2s both}
.btnp{display:inline-flex;align-items:center;gap:.45rem;background:var(--gold);color:var(--deep);padding:.72rem 1.9rem;border-radius:40px;font-size:.82rem;font-weight:500;letter-spacing:.06em;text-transform:uppercase;border:none;cursor:pointer;text-decoration:none;width:fit-content;transition:all .25s;animation:fup .9s .3s both}
.btnp:hover{background:var(--gold-l);transform:translateY(-2px);box-shadow:0 8px 20px rgba(201,168,76,.35)}
.hdots{position:absolute;bottom:1.4rem;left:50%;transform:translateX(-50%);display:flex;gap:.45rem;z-index:3}
.hdot{width:6px;height:6px;border-radius:3px;background:rgba(255,255,255,.4);border:none;cursor:pointer;transition:all .3s}
.hdot.on{background:var(--gold);width:20px}
@keyframes fup{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

/* SHOP */
#shop{padding:3.5rem 1.25rem;max-width:1200px;margin:0 auto}
.sechdr{text-align:center;margin-bottom:2rem}
.seclbl{font-size:.67rem;color:var(--gold-d);letter-spacing:.2em;text-transform:uppercase;margin-bottom:.45rem}
.sectit{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:400;color:var(--deep)}
.secln{width:48px;height:1px;background:var(--gold);margin:1rem auto 0}

/* FILTERS */
.filters{display:flex;gap:.45rem;flex-wrap:wrap;justify-content:center;margin-bottom:2.4rem}
.fb{padding:.4rem 1.1rem;border-radius:30px;border:1.5px solid var(--border);background:var(--white);color:var(--muted);font-size:.76rem;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;letter-spacing:.03em}
.fb:hover,.fb.on{border-color:var(--gold);background:var(--gold);color:var(--deep);font-weight:500}

/* PRODUCT GRID */
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:.9rem}
@media(min-width:540px){.pgrid{grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:1.1rem}}
@media(min-width:900px){.pgrid{grid-template-columns:repeat(auto-fill,minmax(215px,1fr))}}
.pcard{background:var(--white);border-radius:14px;overflow:hidden;box-shadow:0 2px 12px rgba(58,42,30,.07);transition:transform .25s,box-shadow .25s;display:flex;flex-direction:column}
.pcard:hover{transform:translateY(-4px);box-shadow:0 10px 28px rgba(58,42,30,.13)}
.pimg{position:relative;aspect-ratio:1/1;overflow:hidden;background:#f5ede3}
.pimg img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.pcard:hover .pimg img{transform:scale(1.07)}
.pbadge{position:absolute;top:.55rem;left:.55rem;background:var(--deep);color:var(--gold-l);font-size:.58rem;padding:.2rem .55rem;border-radius:20px;letter-spacing:.05em;text-transform:uppercase}
.stk{position:absolute;top:.55rem;right:.55rem;font-size:.58rem;padding:.2rem .55rem;border-radius:20px;font-weight:500}
.stk.ok{background:#d4edda;color:#155724}.stk.no{background:#f8d7da;color:#721c24}
.pinfo{padding:.8rem .8rem .9rem;flex:1;display:flex;flex-direction:column}
.pcat{font-size:.58rem;color:var(--gold-d);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.25rem}
.pname{font-family:'Cormorant Garamond',serif;font-size:.98rem;font-weight:600;color:var(--deep);line-height:1.3;flex:1}
.pdesc{font-size:.68rem;color:var(--muted);margin:.28rem 0 .6rem;line-height:1.5}
.pftr{display:flex;align-items:center;justify-content:space-between;gap:.4rem;margin-top:auto}
.ppr{font-family:'Cormorant Garamond',serif;font-size:1.18rem;font-weight:600;color:var(--deep)}
.atc{background:var(--deep);color:var(--gold-l);border:none;cursor:pointer;padding:.4rem .8rem;border-radius:22px;font-size:.7rem;font-family:'DM Sans',sans-serif;transition:all .2s;white-space:nowrap}
.atc:hover{background:var(--gold);color:var(--deep)}
.atc:disabled{background:#ccc;color:#888;cursor:not-allowed}
.atc.done{background:var(--green);color:#fff}

/* FABS */
.fabs{position:fixed;bottom:1.4rem;right:1.2rem;display:flex;flex-direction:column;gap:.6rem;z-index:800}
.fab{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer;box-shadow:0 4px 16px rgba(0,0,0,.18);transition:transform .2s,box-shadow .2s;text-decoration:none}
.fab:hover{transform:scale(1.1);box-shadow:0 6px 22px rgba(0,0,0,.25)}
.fab-wa{background:var(--wa)}.fab-cart{background:var(--deep);position:relative}
.fab-cart svg{color:var(--gold-l);width:24px;height:24px}
.fcount{position:absolute;top:-4px;right:-4px;background:var(--gold);color:var(--deep);border-radius:50%;min-width:18px;height:18px;font-size:.61rem;font-weight:700;display:flex;align-items:center;justify-content:center;border:2px solid var(--white)}

/* OVERLAY */
.ov{position:fixed;inset:0;background:rgba(26,15,10,.55);z-index:1000;opacity:0;pointer-events:none;transition:opacity .3s}
.ov.on{opacity:1;pointer-events:all}

/* CART DRAWER */
.drawer{position:fixed;top:0;right:0;bottom:0;width:min(420px,100vw);background:var(--white);z-index:1001;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:-8px 0 32px rgba(0,0,0,.12)}
.drawer.on{transform:translateX(0)}
.dhead{padding:1.2rem 1.2rem .9rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.dtit{font-family:'Cormorant Garamond',serif;font-size:1.38rem;font-weight:600;color:var(--deep)}
.xbtn{background:none;border:none;cursor:pointer;width:34px;height:34px;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:background .2s;color:var(--muted)}
.xbtn:hover{background:var(--border)}
.dbody{flex:1;overflow-y:auto;padding:.9rem 1.2rem}
.empty{text-align:center;padding:3rem 1rem;color:var(--muted)}
.empty svg{width:54px;height:54px;opacity:.28;margin-bottom:.9rem}
.empty p{font-family:'Cormorant Garamond',serif;font-size:1.05rem}
.citem{display:flex;gap:.8rem;padding:.85rem 0;border-bottom:1px solid var(--border);animation:sin .25s}
@keyframes sin{from{opacity:0;transform:translateX(14px)}to{opacity:1;transform:translateX(0)}}
.cimg{width:62px;height:62px;border-radius:8px;object-fit:cover;flex-shrink:0;background:#f5ede3}
.cinfo{flex:1;min-width:0}
.cname{font-size:.8rem;font-weight:500;color:var(--deep);line-height:1.3;margin-bottom:.22rem}
.cprc{font-size:.75rem;color:var(--muted)}
.csub{font-size:.8rem;font-weight:600;color:var(--deep);margin-top:.35rem}
.qrow{display:flex;align-items:center;gap:.45rem;margin-top:.35rem}
.qbtn{width:26px;height:26px;border-radius:50%;border:1.5px solid var(--border);background:var(--white);cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center;transition:all .15s;color:var(--deep)}
.qbtn:hover{border-color:var(--gold);background:var(--gold)}
.qbtn:disabled{opacity:.35;cursor:not-allowed}
.qval{font-size:.83rem;font-weight:600;min-width:18px;text-align:center}
.rmbtn{background:none;border:none;cursor:pointer;color:#ccc;font-size:.95rem;padding:.22rem;transition:color .2s;align-self:flex-start}
.rmbtn:hover{color:var(--red)}
.dfoot{padding:.9rem 1.2rem 1.4rem;border-top:1px solid var(--border)}
.delbox{background:#fff8ec;border:1px solid #ffe5b4;border-radius:8px;padding:.55rem .8rem;margin-bottom:.8rem;font-size:.7rem;color:#7a5c00;line-height:1.55}
.trow{display:flex;justify-content:space-between;align-items:center;margin-bottom:.9rem}
.tlbl{font-size:.83rem;color:var(--muted)}.tval{font-family:'Cormorant Garamond',serif;font-size:1.45rem;font-weight:600;color:var(--deep)}
.btnco{width:100%;background:var(--deep);color:var(--gold-l);border:none;cursor:pointer;padding:.95rem;border-radius:12px;font-size:.88rem;font-family:'DM Sans',sans-serif;font-weight:500;letter-spacing:.05em;transition:background .2s}
.btnco:hover{background:var(--gold-d)}

/* MODAL */
.mbg{position:fixed;inset:0;background:rgba(26,15,10,.6);z-index:1100;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s}
@media(min-width:600px){.mbg{align-items:center;padding:1rem}}
.mbg.on{opacity:1;pointer-events:all}
.modal{background:var(--white);width:100%;max-width:500px;max-height:93vh;border-radius:20px 20px 0 0;overflow-y:auto;transform:translateY(60px);transition:transform .35s cubic-bezier(.4,0,.2,1)}
@media(min-width:600px){.modal{border-radius:20px}}
.mbg.on .modal{transform:translateY(0)}
.mhd{padding:1.2rem 1.2rem .7rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--white);z-index:2}
.mtit{font-family:'Cormorant Garamond',serif;font-size:1.32rem;font-weight:600}
.mbody{padding:1.2rem}
.sumbox{background:var(--cream);border-radius:10px;padding:.8rem .95rem;margin-bottom:1.2rem}
.sumlbl{font-size:.67rem;color:var(--gold-d);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.45rem}
.sl{display:flex;justify-content:space-between;font-size:.76rem;color:var(--muted);padding:.16rem 0}
.sl.tot{font-weight:600;color:var(--deep);font-size:.88rem;border-top:1px solid var(--border);padding-top:.45rem;margin-top:.3rem}
.fg{margin-bottom:.95rem}
label{display:block;font-size:.69rem;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.32rem}
label .req{color:var(--red)}
input,textarea,select{width:100%;padding:.62rem .85rem;border:1.5px solid var(--border);border-radius:10px;font-size:.83rem;font-family:'DM Sans',sans-serif;background:var(--white);color:var(--deep);transition:border-color .2s;outline:none;-webkit-appearance:none;appearance:none}
input:focus,textarea:focus,select:focus{border-color:var(--gold)}
textarea{resize:vertical;min-height:65px}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:.7rem}
/* Payment options */
.payopts{display:flex;gap:.7rem;margin-top:.35rem}
.payopt{flex:1;display:flex;align-items:center;gap:.5rem;padding:.6rem .85rem;border:1.5px solid var(--border);border-radius:10px;cursor:pointer;transition:all .2s;font-size:.8rem;font-family:'DM Sans',sans-serif;color:var(--text)}
.payopt input[type=radio]{width:16px;height:16px;min-width:16px;padding:0;margin:0;cursor:pointer;accent-color:var(--gold);flex-shrink:0}
.payopt.selected{border-color:var(--gold);background:#fffbf0}
.btnorder{width:100%;background:var(--gold);color:var(--deep);border:none;cursor:pointer;padding:.95rem;border-radius:12px;font-size:.88rem;font-family:'DM Sans',sans-serif;font-weight:600;letter-spacing:.06em;text-transform:uppercase;transition:all .2s;margin-top:.4rem}
.btnorder:hover{background:var(--gold-l);transform:translateY(-2px)}
.fnote{font-size:.68rem;color:var(--muted);text-align:center;margin-top:.55rem;line-height:1.5}

/* SUCCESS */
.succ{text-align:center;padding:2.4rem 1.5rem;display:none}
.succ.on{display:block}
.sico{width:68px;height:68px;background:#d4edda;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.2rem}
.sico svg{width:34px;height:34px;color:var(--green)}
.stit{font-family:'Cormorant Garamond',serif;font-size:1.55rem;color:var(--deep);margin-bottom:.45rem}
.smsg{font-size:.8rem;color:var(--muted);line-height:1.6;margin-bottom:1.4rem}
.wabtn{display:inline-flex;align-items:center;gap:.45rem;background:var(--wa);color:#fff;padding:.7rem 1.65rem;border-radius:40px;font-size:.83rem;font-weight:500;text-decoration:none;transition:all .2s}
.wabtn:hover{background:#1da856;transform:translateY(-2px)}

/* FOOTER */
footer{background:var(--deep);color:rgba(255,255,255,.65);padding:2.5rem 1.25rem;text-align:center}
.flogo{font-family:'Cormorant Garamond',serif;font-size:1.55rem;color:var(--gold-l);margin-bottom:.22rem}
.ftag{font-size:.67rem;color:var(--gold-d);letter-spacing:.2em;text-transform:uppercase;margin-bottom:1.2rem}
.finfo{font-size:.76rem;line-height:2}
.finfo a{color:var(--gold-l);text-decoration:none}
.fcopy{font-size:.63rem;opacity:.38;margin-top:.9rem}

/* TOAST */
.toast{position:fixed;bottom:5.5rem;left:50%;transform:translateX(-50%) translateY(16px);background:var(--deep);color:var(--gold-l);padding:.6rem 1.35rem;border-radius:30px;font-size:.78rem;z-index:1200;opacity:0;transition:all .3s;white-space:nowrap;pointer-events:none}
.toast.on{opacity:1;transform:translateX(-50%) translateY(0)}
</style>
</head>
