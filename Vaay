<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
/* ══════════════════════════════════════════════════════════════
   ✏️  EDITABLE PRODUCT DATA — update prices, names, stock here
══════════════════════════════════════════════════════════════ */
const PRODUCTS = [
  {id:1,  name:"Red Square Polki Necklace with Earring",            price:499, cat:"Necklace", img:"https://i.ibb.co/gFzSPbpX/1764569334212.png",       desc:"Premium quality necklace set",                inv:1},
  {id:2,  name:"Green Stone Premium Necklace Set with Earring",     price:529, cat:"Necklace", img:"https://i.ibb.co/21LMZP2m/1764570599150.png",        desc:"Premium quality party wear necklace",          inv:1},
  {id:3,  name:"Premium Blue Stone Antique Necklace with Earring",  price:499, cat:"Necklace", img:"https://i.ibb.co/mC05dhX8/1764569526024.png",        desc:"Premium quality necklace set",                inv:1},
  {id:4,  name:"Light Violet Stone Silver Oxidised Necklace Set",   price:389, cat:"Necklace", img:"https://i.ibb.co/ycD7yW59/1765346032878-1.png",      desc:"Premium necklace set for party wear",          inv:1},
  {id:5,  name:"Silver Oxidised Goddess Laxmi Choker with Earring", price:289, cat:"Necklace", img:"https://i.ibb.co/fYZLPMdX/file-00000000d9687209b7d87a3723649daf.png", desc:"Premium quality choker set", inv:1},
  {id:6,  name:"Premium Black Onyx Golden Earring",                 price:299, cat:"Earring",  img:"https://i.ibb.co/N6VDz9xy/IMG-20260312-WA0012.jpg",  desc:"Most trendy and beautiful earring",            inv:2},
  {id:7,  name:"Premium Golden Black Butterfly Hoops Earring",      price:299, cat:"Earring",  img:"https://i.ibb.co/Qj38S8KV/IMG-20260312-WA0010.jpg",  desc:"Premium quality trendy earring",              inv:3},
  {id:8,  name:"Premium Rose Gold AD Stone Roman Hoops Earring",    price:229, cat:"Earring",  img:"https://i.ibb.co/PvvdrSmc/IMG-20260312-WA0017.jpg",  desc:"Premium and trendy earring",                  inv:3},
  {id:9,  name:"Premium Leather Touch Floral Half Hoops Earring",   price:249, cat:"Earring",  img:"https://i.ibb.co/kVv6v5Dq/IMG-20260312-WA0038.jpg",  desc:"Premium quality earring",                     inv:3},
  {id:10, name:"Premium Curly AD Stone Earring",                    price:159, cat:"Earring",  img:"https://i.ibb.co/Y7xB1VRq/IMG-20260312-WA0021.jpg",  desc:"Premium and trendy AD earring",               inv:3},
];

/* ══════════════════════════════════════════════════════════════
   CART
══════════════════════════════════════════════════════════════ */
let cart = JSON.parse(localStorage.getItem('rz2_cart') || '[]');
const save = () => localStorage.setItem('rz2_cart', JSON.stringify(cart));
const gP   = id => PRODUCTS.find(p => p.id === id);
const tot  = ()  => cart.reduce((s,x) => s + gP(x.id).price * x.qty, 0);
const cnt  = ()  => cart.reduce((s,x) => s + x.qty, 0);

function addToCart(id) {
  const p = gP(id), ci = cart.find(x => x.id === id);
  const inCart = ci ? ci.qty : 0;
  if (inCart >= p.inv) { showToast('Only ' + p.inv + ' piece(s) available!'); return; }
  ci ? ci.qty++ : cart.push({id, qty:1});
  save(); badges(); renderCart();
  showToast('Added to cart ✓');
  const btn = document.querySelector('[data-atc="'+id+'"]');
  if (btn) { btn.textContent = '✓ Added'; btn.classList.add('done'); setTimeout(() => { btn.textContent = 'Add to Cart'; btn.classList.remove('done'); }, 1500); }
}

function changeQty(id, d) {
  const ci = cart.find(x => x.id === id);
  if (!ci) return;
  ci.qty += d;
  if (ci.qty <= 0) cart = cart.filter(x => x.id !== id);
  else if (ci.qty > gP(id).inv) { ci.qty = gP(id).inv; showToast('Max stock reached'); }
  save(); badges(); renderCart();
}

function removeItem(id) { cart = cart.filter(x => x.id !== id); save(); badges(); renderCart(); }

function badges() {
  const c = cnt();
  document.getElementById('hBadge').textContent = c;
  document.getElementById('fBadge').textContent = c;
}

/* ══════════════════════════════════════════════════════════════
   RENDER PRODUCTS
══════════════════════════════════════════════════════════════ */
let curF = 'all';
function renderProducts(f) {
  if (f !== undefined) curF = f;
  const grid = document.getElementById('pgrid');
  grid.innerHTML = '';
  PRODUCTS.forEach(p => {
    if (curF !== 'all' && curF !== p.cat) return;
    const ci = cart.find(x => x.id === p.id);
    const atMax = ci && ci.qty >= p.inv;
    const el = document.createElement('div');
    el.className = 'pcard';
    el.innerHTML = `
      <div class="pimg">
        <img src="${p.img}" alt="${p.name}" loading="lazy">
        <span class="pbadge">${p.cat}</span>
        <span class="stk ${p.inv > 0 ? 'ok' : 'no'}">${p.inv > 0 ? 'In Stock' : 'Sold Out'}</span>
      </div>
      <div class="pinfo">
        <div class="pcat">${p.cat}</div>
        <div class="pname">${p.name}</div>
        <div class="pdesc">${p.desc}</div>
        <div class="pftr">
          <span class="ppr">₹${p.price}</span>
          <button class="atc" data-atc="${p.id}"
            ${(!p.inv || atMax) ? 'disabled' : ''}
            onclick="addToCart(${p.id})">
            ${!p.inv ? 'Sold Out' : atMax ? 'Max Qty' : 'Add to Cart'}
          </button>
        </div>
      </div>`;
    grid.appendChild(el);
  });
}

/* ══════════════════════════════════════════════════════════════
   RENDER CART
══════════════════════════════════════════════════════════════ */
function renderCart() {
  const body = document.getElementById('dbody');
  const foot = document.getElementById('dfoot');
  if (!cart.length) {
    body.innerHTML = `<div class="empty"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg><p>Your cart is empty</p></div>`;
    foot.style.display = 'none'; return;
  }
  foot.style.display = 'block';
  body.innerHTML = cart.map(x => {
    const p = gP(x.id);
    return `<div class="citem">
      <img class="cimg" src="${p.img}" alt="${p.name}" loading="lazy">
      <div class="cinfo">
        <div class="cname">${p.name}</div>
        <div class="cprc">₹${p.price} each</div>
        <div class="qrow">
          <button class="qbtn" onclick="changeQty(${p.id},-1)">−</button>
          <span class="qval">${x.qty}</span>
          <button class="qbtn" onclick="changeQty(${p.id},1)" ${x.qty >= p.inv ? 'disabled' : ''}>+</button>
        </div>
        <div class="csub">Subtotal: ₹${p.price * x.qty}</div>
      </div>
      <button class="rmbtn" onclick="removeItem(${p.id})" title="Remove">✕</button>
    </div>`;
  }).join('');
  const t = tot();
  document.getElementById('gtot').textContent = '₹' + t;
  const need = 799 - t;
  document.getElementById('delbox').innerHTML = t >= 799
    ? '🎁 You qualify for <strong>FREE delivery!</strong> 🎉'
    : `Add ₹${need} more for FREE delivery! &nbsp;·&nbsp; COD: ₹89 &nbsp;·&nbsp; Prepaid: ₹49`;
  renderProducts();
}

/* ══════════════════════════════════════════════════════════════
   OPEN/CLOSE PANELS
══════════════════════════════════════════════════════════════ */
function openCart()   { document.getElementById('drawer').classList.add('on'); document.getElementById('ov').classList.add('on'); renderCart(); }
function closeCart()  { document.getElementById('drawer').classList.remove('on'); document.getElementById('ov').classList.remove('on'); }
function closeModal() { document.getElementById('mbg').classList.remove('on'); document.getElementById('ov').classList.remove('on'); }
function closeAll()   { closeCart(); closeModal(); }

function openCheckout() {
  closeCart();
  buildSummary();
  document.getElementById('mbg').classList.add('on');
  document.getElementById('ov').classList.add('on');
  document.getElementById('sScr').classList.remove('on');
  document.getElementById('oForm').style.display = 'block';
  document.getElementById('sumBox').style.display = 'block';
}

/* ══════════════════════════════════════════════════════════════
   ORDER SUMMARY
══════════════════════════════════════════════════════════════ */
function getPayMode() { return document.querySelector('input[name=pay]:checked').value; }

function getDelivery() {
  const t = tot();
  if (t >= 799) return 0;
  return getPayMode() === 'prepaid' ? 49 : 89;
}

function buildSummary() {
  const t = tot(), d = getDelivery();
  const lines = cart.map(x => { const p = gP(x.id); return `<div class="sl"><span>${p.name} × ${x.qty}</span><span>₹${p.price*x.qty}</span></div>`; }).join('');
  const payLabel = getPayMode() === 'prepaid' ? 'Prepaid' : 'COD';
  document.getElementById('sumBox').innerHTML = `
    <div class="sumlbl">Order Summary</div>
    ${lines}
    <div class="sl"><span>Delivery (${payLabel})</span><span>${d===0?'FREE ✓':'₹'+d}</span></div>
    <div class="sl tot"><span>Total Payable</span><span>₹${t+d}</span></div>`;
}

function payChanged() {
  document.getElementById('lCOD').classList.toggle('selected', getPayMode() === 'cod');
  document.getElementById('lPre').classList.toggle('selected', getPayMode() === 'prepaid');
  if (cart.length) buildSummary();
}

/* ══════════════════════════════════════════════════════════════
   PLACE ORDER
══════════════════════════════════════════════════════════════ */
function placeOrder() {
  const name  = document.getElementById('fName').value.trim();
  const phone = document.getElementById('fPhone').value.trim();
  const addr  = document.getElementById('fAddr').value.trim();
  const pin   = document.getElementById('fPin').value.trim();
  const land  = document.getElementById('fLand').value.trim();
  const note  = document.getElementById('fNote').value.trim();
  const pay   = getPayMode() === 'prepaid' ? 'Prepaid / Online Payment' : 'Cash on Delivery (COD)';

  if (!name)  { alert('Please enter your name.'); return; }
  if (!phone) { alert('Please enter your phone number.'); return; }
  if (!addr)  { alert('Please enter your delivery address.'); return; }
  if (!/^\d{6}$/.test(pin)) { alert('Please enter a valid 6-digit pincode.'); return; }

  const t = tot(), d = getDelivery(), grand = t + d;

  const lines = cart.map(x => { const p = gP(x.id); return `  • ${p.name} (x${x.qty}) — ₹${p.price * x.qty}`; }).join('\n');
  const body  = [
    '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━',
    'NEW ORDER — RIWAAZ JEWELRY',
    '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━',
    '',
    'ITEMS ORDERED:',
    lines,
    '',
    `Delivery Charge : ₹${d}`,
    `GRAND TOTAL     : ₹${grand}`,
    `Payment Method  : ${pay}`,
    '',
    '──────────────────────────────',
    'CUSTOMER DETAILS',
    '──────────────────────────────',
    `Name     : ${name}`,
    `Phone    : ${phone}`,
    `Address  : ${addr}`,
    `Pincode  : ${pin}`,
    land ? `Landmark : ${land}` : '',
    note ? `Note     : ${note}` : '',
    '',
    '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━',
  ].filter(l => l !== null && l !== undefined).join('\n');

  document.getElementById('hCart').value = body;
  document.getElementById('hTot').value  = 'Grand Total: ₹' + grand;

  const subj = encodeURIComponent(`New Order from ${name} – ₹${grand} – Riwaaz Jewelry`);
  window.location.href = `mailto:riwaaz485@gmail.com?subject=${subj}&body=${encodeURIComponent(body)}`;

  setTimeout(() => {
    document.getElementById('oForm').style.display = 'none';
    document.getElementById('sumBox').style.display = 'none';
    document.getElementById('sScr').classList.add('on');
    cart = []; save(); badges(); renderCart(); renderProducts();
  }, 700);
}

/* ══════════════════════════════════════════════════════════════
   FILTERS
══════════════════════════════════════════════════════════════ */
document.getElementById('filterRow').addEventListener('click', e => {
  const btn = e.target.closest('.fb');
  if (!btn) return;
  document.querySelectorAll('.fb').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  renderProducts(btn.dataset.f);
});

/* ══════════════════════════════════════════════════════════════
   HERO SLIDER
══════════════════════════════════════════════════════════════ */
let si = 0;
const slides = document.querySelectorAll('.hslide');
const dots   = document.querySelectorAll('.hdot');
function goSlide(i) {
  slides[si].classList.remove('on'); dots[si].classList.remove('on');
  si = i; slides[si].classList.add('on'); dots[si].classList.add('on');
}
setInterval(() => goSlide((si+1) % slides.length), 5000);

/* ══════════════════════════════════════════════════════════════
   TOAST
══════════════════════════════════════════════════════════════ */
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('on');
  setTimeout(() => t.classList.remove('on'), 2200);
}

/* ── INIT ── */
renderProducts(); badges(); renderCart();
</script>
